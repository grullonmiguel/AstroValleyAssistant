<UserControl x:Class="AstroValleyAssistant.Views.Dialogs.MarkerMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AstroValleyAssistant.Views.Dialogs"             
             xmlns:control="clr-namespace:AstroValleyAssistant.Themes.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource Brush.Accent}" Padding="16 10" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header / Title -->
                <TextBlock Text="Properties" Style="{StaticResource Theme.TextBlock.Sidebar.Title}" />

                <ListBox Grid.Row="2" 
                         ItemsSource="{Binding Markers}" 
                         SelectionChanged="MarkerList_SelectionChanged"
                         Style="{StaticResource Theme.ListBox.BaseMapList}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock FontSize="10" >
                                    <Run Text="{Binding Latitude, StringFormat=N4}" />
                                    <Run Text=", " />
                                    <Run Text="{Binding Longitude, StringFormat=N4}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="3" Text="{Binding Status}" 
                           FontStyle="Italic" TextWrapping="Wrap" 
                           Foreground="#FEFEFE" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="16 0 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>


            <Border Background="{StaticResource Brush.Accent}" Padding="16 0" Height="50">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2">

                        <control:IconTextButton 
                            Text="Reset" 
                            Margin="0,0,8,0"
                            Command="{Binding ResetCommand}" 
                            Icon="{StaticResource Icon.MapOutline}"
                            Style="{StaticResource Theme.Button.IconText.Sidebar}"/>
                        
                        <control:IconTextButton 
                            Text="Import" 
                            Margin="0,0,8,0" 
                            Icon="{StaticResource Icon.Excel}"
                            Command="{Binding ImportFileCommand}" 
                            Style="{StaticResource Theme.Button.IconText.Sidebar}"/>

                        <control:IconTextButton 
                            Text="Export" 
                            Margin="0,0,8,0" 
                            Icon="{StaticResource Icon.Excel}"
                            Command="{Binding ExportHtmlCommand}" 
                            Style="{StaticResource Theme.Button.IconText.Sidebar}"/>
                        
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAP -->
            <wv2:WebView2 x:Name="MapWebView" Grid.Row="1"/>

            <Border x:Name="LoadingOverlay" Background="#F0F0F0" Visibility="Collapsed" Grid.Row="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Initializing Map..." FontSize="16" Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="10"/>
                </StackPanel>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>
